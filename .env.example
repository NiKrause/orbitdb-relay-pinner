# Copy to `.env` and adjust. Values below match the built-in defaults (v0.4.0+).

# --- Listeners & transports ---
# RELAY_TCP_PORT=9091
# RELAY_WS_PORT=9092
# RELAY_WEBRTC_PORT=9093
# RELAY_LISTEN_IPV4=0.0.0.0
# RELAY_LISTEN_IPV6=::
# RELAY_DISABLE_IPV6=false
# RELAY_DISABLE_WEBRTC=false
# Public IPFS/libp2p bootstrap peers (Helia/Kubo list) are enabled by default. Set true for isolated networks.
# RELAY_DISABLE_BOOTSTRAP=false

# --- Circuit relay v2 (10× prior v0.3 defaults unless overridden here) ---
# Incoming relay hop must finish within this time (ms). Default: 300000
# RELAY_CIRCUIT_HOP_TIMEOUT_MS=300000

# Max simultaneous relay reservations. Default: 10000
# RELAY_CIRCUIT_MAX_RESERVATIONS=10000

# How long a reservation remains valid (ms). Default: 72000000 (20h)
# RELAY_CIRCUIT_RESERVATION_TTL_MS=72000000

# Max bytes per relayed connection (bigint string). Default: 10737418240 (10 GiB)
# RELAY_CIRCUIT_DEFAULT_DATA_LIMIT_BYTES=10737418240

# Max duration (ms) a single relayed circuit may stay open. Default: 1200000 (20 min)
# RELAY_CIRCUIT_DEFAULT_DURATION_LIMIT_MS=1200000

# --- Metrics & datastore ---
# METRICS_PORT=9090
# METRICS_DISABLED=false
# CORS for /health, /multiaddrs, /metrics, /pinning/*, /ipfs/* (browser dashboards). Default: * (any origin).
# METRICS_CORS_ORIGIN=*
# Allowlist (comma-separated, exact origins): https://app.example.com,http://localhost:5173
# Optional: METRICS_CORS_ALLOW_HEADERS=Content-Type,Authorization
# DATASTORE_PATH=./orbitdb/pinning-service

# --- Discovery & identity ---
# PUBSUB_TOPICS=todo._peer-discovery._p2p._pubsub
# TEST_PRIVATE_KEY=
# RELAY_PRIV_KEY=

# --- TLS (optional) ---
# disableAutoTLS=
# STAGING=false
