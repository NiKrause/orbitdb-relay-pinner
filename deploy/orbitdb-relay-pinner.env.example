# Copy to /etc/default/orbitdb-relay-pinner (Debian/Ubuntu) or merge into your EnvironmentFile.
# This port block (28190–28193) is chosen to avoid Kubo defaults: swarm 4001, API 5001, gateway 8080.
#
# Nym VPN: clients exiting through Nym mixnet must use destination ports allowed by
# https://nymtech.net/.wellknown/network-requester/exit-policy.txt — see docs/nym-vpn-ports.md
# (e.g. METRICS_PORT=8008, RELAY_WS_PORT=6300, TCP/UDP in 50000–65535).

# Persistent state (PeerId + LevelDB). Must be writable by the service user.
DATASTORE_PATH=/var/lib/orbitdb-relay-pinner

# Prometheus / health / multiaddrs JSON (see metrics service).
METRICS_PORT=28190
# Optional HTTPS on same routes using AutoTLS PEM (valid host: one label under peerId.libp2p.direct — see docs/http-api.md).
# METRICS_HTTPS_ENABLED=1
# METRICS_HTTPS_PORT=9443
# Browser CORS for those HTTP routes (default any origin). Production: comma-separated allowlist.
# METRICS_CORS_ORIGIN=*

# libp2p listeners — keep in sync with firewall and optional VITE_APPEND_ANNOUNCE below.
RELAY_TCP_PORT=28191
RELAY_WS_PORT=28192
RELAY_WEBRTC_PORT=28193

# WebSocket on port 80 (e.g. restrictive firewalls): set RELAY_WS_PORT=80 and use the same port in
# VITE_APPEND_ANNOUNCE (…/tcp/80/ws). Requires systemd CAP_NET_BIND_SERVICE — see
# deploy/orbitdb-relay-pinner-ws-port80.conf.example. Ensure nothing else binds :80 (nginx, Apache, Kubo).
# RELAY_WS_PORT=80

# Bind v4 only on the public interface if you use split networking; default is all interfaces.
# RELAY_LISTEN_IPV4=0.0.0.0

# On a VPS with a static public IP, set appendAnnounce so AutoNAT + AutoTLS see the correct dialable addrs.
# Replace PUBLIC_IP with your host’s IPv4 (e.g. the A record for ipfs.le-space.de).
# VITE_APPEND_ANNOUNCE=/ip4/PUBLIC_IP/tcp/28191,/ip4/PUBLIC_IP/tcp/28192/ws,/ip4/PUBLIC_IP/udp/28193/webrtc-direct

# Disable UDP WebRTC if your provider blocks arbitrary UDP (AutoTLS still works over TCP/WS).
# RELAY_DISABLE_WEBRTC=1

# IPv6 off if you do not expose v6 to the internet.
# RELAY_DISABLE_IPV6=1

# By default the relay uses public IPFS/libp2p bootstrap nodes (Helia/Kubo list) to join the main DHT swarm.
# Set only for air-gapped or fully private networks.
# RELAY_DISABLE_BOOTSTRAP=1

# Inbound-only: disconnect peers after Identify if they advertise no /orbitdb/heads/* protocol (OrbitDB sync).
# Outbound bootstrap/DHT dials are unaffected. Default off.
# RELAY_REQUIRE_ORBITDB_HEADS_PROTOCOL=1

# Disable AutoNAT if you want to avoid external address probing/churn on a public relay.
# RELAY_DISABLE_AUTONAT=1

# AutoTLS (@ipshipyard/libp2p-auto-tls) is ON by default. Uncomment only to disable.
# disableAutoTLS=1

# Use Let’s Encrypt staging while testing certificate flow.
# STAGING=true

# Optional: same as VITE_APPEND_ANNOUNCE; comma-separated pubsub discovery topics.
# PUBSUB_TOPICS=todo._peer-discovery._p2p._pubsub

# Optional libp2p connectivity debug/test protocols. Disabled by default; enable only when you want to
# probe the relay with /connectivity-echo/1.0.0 or /connectivity-bulk/1.0.0 from test tooling.
# RELAY_CONNECTIVITY_ECHO_ENABLED=1
# RELAY_CONNECTIVITY_BULK_ENABLED=1
# RELAY_CONNECTIVITY_BULK_MAX_FRAME_BYTES=262144
# RELAY_CONNECTIVITY_BULK_READ_TIMEOUT_MS=10000
# RELAY_CONNECTIVITY_BULK_IDLE_TIMEOUT_MS=30000

# libuv thread pool size (default 4). Used for async crypto, fs, dns.lookup, etc. Raising or lowering
# can affect rare Node aborts: Assertion `errors->Empty()' in crypto CipherJob — see docs/systemd-deployment.md.
# UV_THREADPOOL_SIZE=1

# --- Verbose logging (see AGENTS.md, src/config/logging.ts) ---
# ENABLE_GENERAL_LOGS=1          # le-space:relay:* (@libp2p/logger), startup multiaddrs / PeerId
# ENABLE_SYNC_LOGS=1             # sync queue, pubsub, open db, CID extract, pin steps (le-space:relay:sync)
# ENABLE_SYNC_STATS=1            # console lines: DB_SYNC record counts per database type
# LOG_LEVEL_CONNECTION=true      # connection:open
# LOG_LEVEL_PEER=true            # peer:connect + identify errors
# LOG_LEVEL_DATABASE=true        # sync/pin failures to console.error
# LOG_LEVEL_SYNC=true            # reserved (unused in current code)
# ENABLE_HEADS_STREAM_LOGS=0     # set 0 to silence libp2p heads stream debug
