[Unit]
Description=OrbitDB relay and pinning service (Helia/libp2p, AutoTLS)
Documentation=https://github.com/NiKrause/orbitdb-relay-pinner/blob/main/docs/systemd-deployment.md
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=orbitdb-relay
Group=orbitdb-relay
WorkingDirectory=/opt/orbitdb-relay-pinner

# Environment variables: copy deploy/orbitdb-relay-pinner.env.example to /etc/default/orbitdb-relay-pinner
EnvironmentFile=-/etc/default/orbitdb-relay-pinner

# Node 22+ required (see package.json engines).
ExecStart=/usr/bin/node /opt/orbitdb-relay-pinner/node_modules/orbitdb-relay-pinner/dist/cli.js

Restart=on-failure
RestartSec=10

# Hardening (adjust if you hit permission issues with the datastore path)
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=true
ProtectHome=true
ReadWritePaths=/var/lib/orbitdb-relay-pinner

[Install]
WantedBy=multi-user.target
