# Optional: line-buffer stdout/stderr so logs show up quickly in files (Node/weald often block-buffers non-TTY).
# Install as e.g. /etc/systemd/system/orbitdb-relay-pinner.service.d/line-buffer.conf
# Requires: /usr/bin/stdbuf (coreutils).
#
# Warning: `stdbuf` uses LD_PRELOAD; on some hosts it has interacted badly with native addons (odd
# shutdown / std::system_error). Prefer file logging without this first; add only if `tail -f` stays stale.

[Service]
ExecStart=
ExecStart=/usr/bin/stdbuf -oL -eL /usr/bin/node /opt/orbitdb-relay-pinner/node_modules/orbitdb-relay-pinner/dist/cli.js
