# Use when METRICS_PORT / RELAY_* / WebRTC use ports < 1024 (e.g. 81–84 or WS on 80).
#
# systemd: if the main unit sets NoNewPrivileges=true, AmbientCapabilities are IGNORED for a
# non-root User=, so binding fails with errno 13 (EACCES). This drop-in turns that off so
# CAP_NET_BIND_SERVICE can reach the Node/WebRTC process.
#
# Install:
#   sudo mkdir -p /etc/systemd/system/orbitdb-relay-pinner.service.d
#   sudo cp deploy/orbitdb-relay-pinner-low-ports.conf.example \
#     /etc/systemd/system/orbitdb-relay-pinner.service.d/low-ports.conf
#   sudo systemctl daemon-reload
#   sudo systemctl restart orbitdb-relay-pinner

[Service]
NoNewPrivileges=false
AmbientCapabilities=CAP_NET_BIND_SERVICE
CapabilityBoundingSet=CAP_NET_BIND_SERVICE
