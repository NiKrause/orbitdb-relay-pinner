# Append all stdout/stderr to a file (in addition to or instead of journald for app output).
# systemd opens the file before switching User=, so /var/log/... works.
#
#   sudo mkdir -p /var/log/orbitdb-relay-pinner
#   sudo touch /var/log/orbitdb-relay-pinner/relay.log
#   sudo chown orbitdb-relay:orbitdb-relay /var/log/orbitdb-relay-pinner /var/log/orbitdb-relay-pinner/relay.log
#   sudo chmod 750 /var/log/orbitdb-relay-pinner
#   sudo cp deploy/orbitdb-relay-pinner-file-log.conf.example \
#     /etc/systemd/system/orbitdb-relay-pinner.service.d/file-log.conf
#   sudo systemctl daemon-reload
#   sudo systemctl restart orbitdb-relay-pinner
#
# Follow: sudo tail -f /var/log/orbitdb-relay-pinner/relay.log
#
# Pair with verbose env vars in /etc/default/orbitdb-relay-pinner (see deploy/orbitdb-relay-pinner.env.example).

[Service]
StandardOutput=append:/var/log/orbitdb-relay-pinner/relay.log
StandardError=append:/var/log/orbitdb-relay-pinner/relay.log
